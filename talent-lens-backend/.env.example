# Server Configuration
PORT=
FRONTEND_URL=

# Database Configuration
# Replace <password> and <your-cluster-url>.
# Keep your database user as Admin.
MONGO_URI=
MONGO_SERVER_SELECTION_TIMEOUT_MS=
MONGO_CONNECT_TIMEOUT_MS=

# Security
# Use a long random string in production.
JWT_SECRET=
JWT_EXPIRES_IN=

# AI Integration
# Required for the Gemini integration phase.
GEMINI_API_KEY=
# Optional: override the Gemini model used by screening.
GEMINI_MODEL=
GEMINI_MODEL_FALLBACKS=

# Bulk Upload Tuning
GEMINI_RESUME_TEXT_LIMIT=
GEMINI_RATE_LIMIT_MAX_RETRIES=
GEMINI_RATE_LIMIT_BASE_BACKOFF_MS=
GEMINI_RATE_LIMIT_MIN_BACKOFF_MS=
BULK_UPLOAD_THROTTLE_THRESHOLD=
BULK_UPLOAD_THROTTLE_DELAY_MS=

# Upload Configuration
UPLOAD_MAX_FILE_SIZE_MB=

